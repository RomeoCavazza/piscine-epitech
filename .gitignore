# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Windows Zone.Identifier files (created automatically by Windows)
*.Zone.Identifier
**/*.Zone.Identifier

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Uploads
uploads/

# Compiled class files
*.class

# VirtualBox files
*.vbox
*.vbox-prev
*.vdi
*.sav
**/Logs/
**/Snapshots/

# ISO files (too large for Git)
*.iso

# PDF files (intellectual property - replaced by OBJECTIVES.md)
*.pdf

# Rust build artifacts
**/target/
**/*.rs.bk
Cargo.lock
backend/target/

# Python virtual environments
.venv/
venv/
ENV/
env/

# Node / Next (hello-world)
frontend/node_modules/
frontend/.next/

# Env (hello-world)
backend/.env
frontend/.env
frontend/.env.local
